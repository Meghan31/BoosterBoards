# -----------------------------
# Root-level
# -----------------------------
.DS_Store
Thumbs.db

# IDE / local workspace
.vscode/
.agents/

# Env files
.env
.env.*
!.env.example


# -----------------------------
# Frontend (Next.js) - /frontend
# -----------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/
frontend/.vercel/
frontend/coverage/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*


# -----------------------------
# Backend (Django) - /backend
# -----------------------------
# Python cache
backend/__pycache__/
backend/**/*.py[cod]
backend/*$py.class

# Virtual environments
backend/venv/
backend/.venv/
backend/env/
backend/.env/

# Build / packaging
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/

# Tool caches
backend/.mypy_cache/
backend/.pytest_cache/
backend/.ruff_cache/
backend/.tox/
backend/.nox/
backend/.coverage
backend/.coverage.*
backend/htmlcov/

# Django files
backend/db.sqlite3
backend/db.sqlite3-journal
backend/local_settings.py
backend/media/
backend/staticfiles/

# Logs
backend/*.log
