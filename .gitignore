.DS_Store
Thumbs.db

# IDE / local workspace
.vscode/
.agents/

# Env files
.env
.env.*
!.env.example


# -----------------------------
# Frontend (Next.js) - /frontend-bb
# -----------------------------
frontend-bb/node_modules/
frontend-bb/.next/
frontend-bb/out/
frontend-bb/build/
frontend-bb/.turbo/
frontend-bb/.vercel/
frontend-bb/coverage/
