# -----------------------------
# Backend (Django) - /backend-bb
# -----------------------------
# Python cache
backend-bb/__pycache__/
backend-bb/**/*.py[cod]
backend-bb/*$py.class

# Virtual environments
backend-bb/venv/
backend-bb/.venv/
backend-bb/env/
backend-bb/.env/

# Build / packaging
backend-bb/build/
backend-bb/dist/
backend-bb/*.egg-info/
backend-bb/.eggs/

# Tool caches
backend-bb/.mypy_cache/
backend-bb/.pytest_cache/
backend-bb/.ruff_cache/
backend-bb/.tox/
backend-bb/.nox/
backend-bb/.coverage
backend-bb/.coverage.*
backend-bb/htmlcov/

# Django files
backend-bb/db.sqlite3
backend-bb/db.sqlite3-journal
backend-bb/local_settings.py
backend-bb/media/
backend-bb/staticfiles/

# Logs
backend-bb/*.log
